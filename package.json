{
  "name": "@js_cipher/svgpen",
  "version": "0.1.0",
  "description": "Canvas-like API for SVG",
  "main": "dist/index.umd.js",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "svg",
    "graphics",
    "vector",
    "vanilla"
  ],
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.js --bundle --minify --format=esm --outfile=dist/index.esm.js && esbuild src/index.js --bundle --minify --format=iife --global-name=SVG --outfile=dist/index.umd.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.23.1"
  }
}
